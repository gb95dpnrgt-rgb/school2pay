# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM=School2Pay <payments@yourdomain.com>

# Magic link signing (min 32 chars, keep secret)
MAGIC_LINK_SECRET=change-me-to-a-random-32-plus-char-string

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Server-side base URL for Stripe return/refresh URLs (overrides NEXT_PUBLIC_APP_URL in server actions)
APP_URL=https://your-app.vercel.app

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=school2pay
# SENTRY_AUTH_TOKEN is only needed at build time for source-map upload
SENTRY_AUTH_TOKEN=

# Resend webhook (for bounce tracking)
RESEND_WEBHOOK_SECRET=whsec_...

# Cron job secret (Vercel calls /api/cron/reminders with this in x-cron-secret header)
CRON_SECRET=change-me-to-a-random-secret

# Twilio SMS (optional — leave blank to disable SMS reminders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+44...

# Spike page (set to "true" only in local dev / staging)
NEXT_PUBLIC_ENABLE_SPIKE=
